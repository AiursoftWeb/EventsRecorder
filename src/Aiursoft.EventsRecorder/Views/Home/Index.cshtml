@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/styles/site.css" xmlns="http://www.w3.org/1999/html"/>
    <link rel="stylesheet" href="~/styles/marketing.css" xmlns="http://www.w3.org/1999/html"/>
}

<vc:marketing-navbar></vc:marketing-navbar>

<section class="landing-intro text-bg-dark pt-5 pt-lg-6 pb-5 pb-lg-7">
    <div class="landing-intro-content container h-100">
        <div class="row align-items-center h-100">
            <div class="col-lg-5 mx-auto">
                <span class="badge badge-subtle-primary p-1">@Localizer["Open Source"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["Free"]</span>
                <span class="badge badge-subtle-primary p-1">@Localizer["MIT Licence"]</span>
                <h1 id="main-slogan" class="my-4 text-white" style="font-size: 3rem;">
                    @Localizer["Track What Matters."] <span class='text-primary'>@Localizer["Record Everything."]</span>
                </h1>
                <p class="text-lg text-white-50">@Localizer["Define your own event types with custom fields, then log every occurrence with structured data. Understand your habits, activities, and history at a glance."]</p>
                <div class="my-4">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="rocket"></i> @Localizer["Get started for free"]
                    </a>
                    <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-primary btn-lg btn-pill">
                        <i class="align-middle" data-lucide="grid"></i> @Localizer["Go to dashboard"]
                    </a>
                </div>
            </div>
            <div class="col-lg-7 d-none d-lg-flex mx-auto text-center">
                <div class="landing-intro-screenshot">
                    <img src="~/images/screenshot.png" alt="EventsRecorder screenshot" class="img-fluid" />
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Core Features"]</span>
            <h2 class="h1">@Localizer["Everything you need to track structured events."]</h2>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="list-checks"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Custom Event Types"]</h4>
                        <p class="fs-lg">@Localizer["Define your own event types with names and descriptions tailored to your specific tracking needs."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="sliders"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Flexible Field Definitions"]</h4>
                        <p class="fs-lg">@Localizer["Attach custom fields of various types to each event type — text, numbers, booleans, and more — with configurable order and required constraints."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="clock"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Timestamped Records"]</h4>
                        <p class="fs-lg">@Localizer["Every event record is automatically timestamped in UTC so you can accurately reconstruct a history of occurrences over time."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="notebook-pen"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Notes & Context"]</h4>
                        <p class="fs-lg">@Localizer["Add free-form notes to any event record for additional context that doesn't fit neatly into structured fields."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="users"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Multi-User Support"]</h4>
                        <p class="fs-lg">@Localizer["Each user manages their own isolated event types and records. Built-in RBAC ensures administrators can oversee all activity."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="bar-chart-2"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Historical Browsing"]</h4>
                        <p class="fs-lg">@Localizer["Browse, search, and filter your event history to spot patterns, review past activity, and gain insights from your long-term data."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="immersive-section position-relative w-100 overflow-hidden d-flex align-items-center">
    
    <div class="immersive-bg">
        <div class="bg-image-wrapper">
             <img src="~/images/template_running_in_docker.webp" alt="EventsRecorder running in Docker" class="img-fluid object-fit-cover w-100 h-100">
        </div>
        <div class="bg-overlay"></div>
    </div>

    <div class="container position-relative z-2 py-5">
        <div class="row">
            <div class="col-lg-6 offset-lg-6 col-md-12">
                
                <div class="mb-5 text-start ps-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-info me-2"><i class="fas fa-server"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Self Hosted"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">@Localizer["Single Container"]</span><br>
                        @Localizer["Fully Offline"]
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["No dependency on any cloud vendor. Run anywhere, any time — your data stays with you."]
                    </p>
                </div>

                <div class="row g-3 ps-lg-4">
                    
                    @* Card 1: One Click Start *@
                    <div class="col-md-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-success-subtle text-success rounded-3 me-3 mb-3">
                                    <i class="fas fa-play-circle fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["One Click Start"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm"> @Localizer["Start with a single 'docker run' command."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 2: No Internet Required *@
                    <div class="col-md-6">
                         <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4">
                                <div class="icon-box-sm bg-info-subtle text-info rounded-3 me-3 mb-3">
                                    <i class="fas fa-wifi fa-lg"></i>
                                </div>
                                <h5 class="fw-bold text-white fs-6">@Localizer["Fully Offline"]</h5>
                                <p class="text-gray-400 mb-0 lh-sm"> @Localizer["Runs without any internet connection required."]</p>
                            </div>
                        </div>
                    </div>

                    @* Card 3: Zero Config *@
                    <div class="col-12">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift">
                            <div class="card-body p-4 d-flex align-items-center">
                                <div class="icon-box-sm bg-white-10 text-white rounded-3 me-3">
                                    <i class="fas fa-database"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold text-white mb-1 fs-6"> @Localizer["Zero Configuration"]</h5>
                                    <p class="text-gray-400 mb-0">@Localizer["Default SQLite database, no configuration needed."]</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift text-center py-2">
                            <div class="card-body p-2">
                                <i class="fas fa-user-shield text-warning mb-2 fs-5"></i>
                                <div class="text-gray-300 fw-bold" style="font-size: 0.75rem">@Localizer["Built-in Auth"]</div>
                                <div class="text-gray-500">@Localizer["Full RBAC"]</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-dark-glass border-white-10 h-100 hover-lift text-center py-2">
                            <div class="card-body p-2">
                                <i class="fas fa-sync text-primary mb-2 fs-5"></i>
                                <div class="text-gray-300 fw-bold" style="font-size: 0.75rem">@Localizer["Unified Env"]</div>
                                <div class="text-gray-500">@Localizer["Dev & Prod"]</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>


<section class="py-6">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["How It Works"]</span>
            <h2 class="h1">@Localizer["Three simple steps to structured event tracking."]</h2>
        </div>

        <div class="row">
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="plus-circle"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["1. Define an Event Type"]</h4>
                        <p class="fs-lg">@Localizer["Create a named event type such as 'Morning Run', 'Medicine Intake', or 'Work Session'. Add a description so everyone knows what it tracks."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="table"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["2. Configure Custom Fields"]</h4>
                        <p class="fs-lg">@Localizer["Add the data fields that matter for this event — Distance, Duration, Medication Name, Dosage — choosing the field type and whether each is required."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="pen-line"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["3. Log Every Occurrence"]</h4>
                        <p class="fs-lg">@Localizer["Each time the event happens, create a record. Fill in the field values, optionally add notes, and the timestamp is captured automatically."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="check-circle-2"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Validation Built In"]</h4>
                        <p class="fs-lg">@Localizer["Fields are validated on both client and server sides, ensuring your data is clean and consistent across all records."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="database"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Multiple Database Support"]</h4>
                        <p class="fs-lg">@Localizer["Choose from SQLite, MySQL, or SQL Server depending on your scale. Easily swap providers with minimal configuration."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4 d-flex">
                <div class="d-flex align-items-start py-3">
                    <div class="landing-feature">
                        <i data-lucide="settings-2"></i>
                    </div>
                    <div class="flex-grow-1">
                        <h4 class="mt-0">@Localizer["Admin Settings"]</h4>
                        <p class="fs-lg">@Localizer["Administrators can manage global settings through the dashboard, with environment variable overrides for production deployments."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-light">
    <div class="container">
        <div class="mb-5 text-center px-4">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["Use Cases"]</span>
            <h2 class="h1">@Localizer["What can you track with EventsRecorder?"]</h2>
            <div class="row justify-content-center">
                <div class="col-lg-10 col-xl-8">
                    <p class="text-muted fs-lg">
                        @Localizer["From personal health habits to team workflow checkpoints, EventsRecorder adapts to any structured data you want to capture over time."]
                    </p>
                </div>
            </div>
        </div>
        <div class="row g-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="heart-pulse" class="text-danger" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Health & Fitness"]</h5>
                        <p class="text-muted mb-0">@Localizer["Log runs, workouts, medicine intake, sleep hours, or blood pressure readings with custom fields for every metric that matters to you."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="briefcase" class="text-primary" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Work & Productivity"]</h5>
                        <p class="text-muted mb-0">@Localizer["Track work sessions, meeting outcomes, task completions, or any recurring workplace activity with structured data fields."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="book-open" class="text-success" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Learning & Habits"]</h5>
                        <p class="text-muted mb-0">@Localizer["Record daily reading sessions, language practice, study hours, or any habit you want to build — with progress visible over time."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="wrench" class="text-warning" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Maintenance Logs"]</h5>
                        <p class="text-muted mb-0">@Localizer["Track vehicle maintenance, home repairs, equipment servicing, or any periodic maintenance activity with timestamped records."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="leaf" class="text-success" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Nature & Hobbies"]</h5>
                        <p class="text-muted mb-0">@Localizer["Log garden watering, bird sightings, photography outings, or any hobby with the exact custom fields your activity demands."]</p>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border shadow-sm">
                    <div class="card-body p-4">
                        <div class="mb-3">
                            <i data-lucide="zap" class="text-info" style="width:32px;height:32px;"></i>
                        </div>
                        <h5 class="fw-bold">@Localizer["Anything Else"]</h5>
                        <p class="text-muted mb-0">@Localizer["EventsRecorder is schema-flexible. If you have a recurring event you want to capture in a structured way, it fits right in."]</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-6 bg-white">
    <div class="container">
        <div class="mb-5 text-center">
            <span class="text-uppercase text-primary text-sm fw-medium mb-1 d-block">@Localizer["FAQ"]</span>
            <h2 class="h1">@Localizer["Frequently asked questions"]</h2>
            <p class="text-muted fs-lg">@Localizer["Here are some of the answers you might be looking for."]</p>
        </div>

        <div class="row">
            <div class="col-md-9 col-lg-8 mx-auto">
                <div class="accordion" id="accordionFaq">
                    <div class="card border mb-3">
                        <div class="card-header cursor-pointer" id="faqZero" data-bs-toggle="collapse" data-bs-target="#collapseZero" aria-expanded="false" aria-controls="collapseZero">
                            <h6 class="mb-0">@Localizer["What is an Event Type?"]</h6>
                        </div>
                        <div id="collapseZero" class="collapse" aria-labelledby="faqZero" data-bs-parent="#accordionFaq">
                            <div class="card-body py-3">
                                @Localizer["An Event Type is a template for a category of events you want to track. For example, 'Morning Run' or 'Medicine Intake'. Each Event Type can have custom fields so you always capture exactly the data you need."]
                            </div>
                        </div>
                    </div>
                    <div class="card border mb-3">
                        <div class="card-header cursor-pointer" id="faqOne" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                            <h6 class="mb-0">@Localizer["What field types are supported?"]</h6>
                        </div>
                        <div id="collapseOne" class="collapse" aria-labelledby="faqOne" data-bs-parent="#accordionFaq">
                            <div class="card-body py-3">
                                @Localizer["EventsRecorder supports multiple field types including text, numbers, and booleans. Each field can be marked as required and assigned a display order, giving you full control over the data structure."]
                            </div>
                        </div>
                    </div>
                    <div class="card border mb-3">
                        <div class="card-header cursor-pointer" id="faqTwo" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                            <h6 class="mb-0">@Localizer["Can multiple users share the same instance?"]</h6>
                        </div>
                        <div id="collapseTwo" class="collapse" aria-labelledby="faqTwo" data-bs-parent="#accordionFaq">
                            <div class="card-body py-3">
                                @Localizer["Yes. EventsRecorder supports multiple users on a single instance. Each user has their own private event types and records. Administrators have additional oversight capabilities through the built-in RBAC system."]
                            </div>
                        </div>
                    </div>
                    <div class="card border mb-3">
                        <div class="card-header cursor-pointer" id="faqThree" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                            <h6 class="mb-0">@Localizer["How do I deploy EventsRecorder?"]</h6>
                        </div>
                        <div id="collapseThree" class="collapse" aria-labelledby="faqThree" data-bs-parent="#accordionFaq">
                            <div class="card-body py-3">
                                @Localizer["The easiest way is Docker: a single 'docker run' command is all you need. EventsRecorder is fully self-contained and works offline with SQLite by default. You can also install it directly on Ubuntu via the provided install script, or run it locally with the .NET 10 SDK."]
                            </div>
                        </div>
                    </div>
                    <div class="card border mb-3">
                        <div class="card-header cursor-pointer" id="faqFour" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                            <h6 class="mb-0">@Localizer["Is EventsRecorder free to use?"]</h6>
                        </div>
                        <div id="collapseFour" class="collapse" aria-labelledby="faqFour" data-bs-parent="#accordionFaq">
                            <div class="card-body py-3">
                                @Localizer["Yes, EventsRecorder is completely free and open-source under the MIT License. You can use it for personal or commercial purposes at no cost and self-host it on your own infrastructure."]
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="immersive-section position-relative w-100 overflow-hidden d-flex align-items-center border-top border-white-10">
    
    <div class="immersive-bg">
        <div class="bg-image-wrapper clean-wrapper">
            <img src="~/images/github.webp" alt="EventsRecorder on GitLab" class="img-fluid object-fit-cover w-100 h-100">
        </div>
        <div class="bg-overlay"></div>
    </div>

    <div class="container position-relative z-2 py-5">
        <div class="row">
            <div class="col-lg-6 offset-lg-6 col-md-12">
                
                <div class="mb-5 text-start ps-lg-4">
                    <div class="d-inline-flex align-items-center px-3 py-1 mb-3 rounded-pill border border-white-10 bg-dark-glass-sm backdrop-blur">
                        <span class="text-warning me-2"><i class="fab fa-gitlab"></i></span>
                        <span class="text-gray-300 small fw-medium text-uppercase tracking-wider">@Localizer["Free Software"]</span>
                    </div>
                    <h2 class="display-4 fw-bold text-white mb-3">
                        <span class="text-primary">@Localizer["EventsRecorder"]</span><br>
                        @Localizer["is Free Software"]
                    </h2>
                    <p class="lead text-gray-400 fs-5">
                        @Localizer["Fully open source. No paid tiers, no vendor lock-in. Your data stays on your infrastructure."]
                    </p>
                    <p class="text-gray-400">
                        @Localizer["Self-host it, fork it, and adapt it to your needs freely under the MIT License."]
                    </p>
                    
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span class="badge bg-success-subtle text-success border border-success-subtle p-2">
                            <i class="fas fa-balance-scale me-1"></i> @Localizer["MIT License"]
                        </span>
                        <span class="badge bg-info-subtle text-info border border-info-subtle p-2">
                            <i class="fas fa-store me-1"></i> @Localizer["Free for Commercial Use"]
                        </span>
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle p-2">
                            <i class="fas fa-code me-1"></i> @Localizer["Full Stack Open Source"]
                        </span>
                    </div>

                    <div class="mt-4">
                        <a href="https://gitlab.aiursoft.com/aiursoft/eventsRecorder" target="_blank" class="btn btn-primary btn-lg btn-pill">
                            <i class="fab fa-gitlab me-2"></i> @Localizer["View Source Code"]
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<section class="py-6">
    <div class="container text-center">
        <div class="row">
            <div class="col-12 col-md-10 col-lg-9 col-xl-8 mx-auto">
                <h2 class="h1 mb-3">
                    @Localizer["Start recording your events today!"]
                </h2>
                <p class="text-muted fs-lg mb-4">@Localizer["Sign up for free and start defining your event types in minutes."]</p>
                <a asp-controller="Account" asp-action="Register" class="align-middle btn btn-primary btn-pill btn-lg mt-n1">
                    <i class="fa-solid fa-rocket"></i>
                    <span class="ms-1">@Localizer["Get started for free"]</span>
                </a>
                <a asp-controller="Dashboard" asp-action="Index" class="align-middle btn btn-outline-secondary btn-pill btn-lg mt-n1 ms-2">
                    <i class="fa-solid fa-grid"></i>
                    <span class="ms-1">@Localizer["Go to dashboard"]</span>
                </a>
            </div>
        </div>
    </div>
</section>

<vc:marketing-footer></vc:marketing-footer>

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script>
        window.addEventListener('load', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            })
        });
    </script>
}
