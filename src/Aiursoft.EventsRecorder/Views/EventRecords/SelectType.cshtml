@model Aiursoft.EventsRecorder.Models.EventRecordsViewModels.SelectTypeViewModel

<div class="text-center mt-5 mb-4">
    <h1 class="display-4">@Localizer["Record!"]</h1>
    <p class="text-muted">@Localizer["Select an event type to record"]</p>
</div>

@if (!Model.EventTypes.Any())
{
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body text-center py-5">
                    <i class="align-middle text-muted mb-3" data-lucide="layers" style="width: 48px; height: 48px;"></i>
                    <h4 class="text-muted">@Localizer["No event types defined"]</h4>
                    <p class="text-muted">@Localizer["Create an event type first, then come back to record."]</p>
                    <a asp-controller="EventTypes" asp-action="Create" class="btn btn-primary">
                        <i class="align-middle" data-lucide="plus-circle"></i> @Localizer["Create Event Type"]
                    </a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="row justify-content-center">
        @foreach (var et in Model.EventTypes)
        {
            <div class="col-6 col-md-4 col-lg-3 mb-4">
                <a asp-action="Record" asp-route-eventTypeId="@et.Id" class="text-decoration-none">
                    <div class="card h-100 text-center border-2 hover-shadow" style="cursor:pointer; transition: all 0.2s;">
                        <div class="card-body d-flex flex-column justify-content-center py-5">
                            <i class="align-middle text-primary mb-3" data-lucide="pen-line" style="width: 36px; height: 36px; margin: 0 auto;"></i>
                            <h5 class="card-title mb-0">@et.Name</h5>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}
