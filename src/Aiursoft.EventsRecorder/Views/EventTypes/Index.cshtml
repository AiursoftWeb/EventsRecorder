@using Aiursoft.WebTools
@model Aiursoft.EventsRecorder.Models.EventTypesViewModels.IndexViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["My Event Types"]</h3>
    </div>
    <div class="col-auto ms-auto mt-n1">
        <a asp-action="Create" class="btn btn-primary">
            <i class="align-middle" data-lucide="plus-circle"></i> @Localizer["Create Event Type"]
        </a>
    </div>
</div>

@if (!Model.EventTypes.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="align-middle text-muted mb-3" data-lucide="layers" style="width: 48px; height: 48px;"></i>
            <h4 class="text-muted">@Localizer["No event types yet"]</h4>
            <p class="text-muted">@Localizer["Create your first event type to start recording events."]</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="align-middle" data-lucide="plus-circle"></i> @Localizer["Create Event Type"]
            </a>
        </div>
    </div>
}
else
{
    <div class="row">
        @foreach (var item in Model.EventTypes)
        {
            <div class="col-12 col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none">@item.Name</a>
                        </h5>
                        @if (!string.IsNullOrWhiteSpace(item.Description))
                        {
                            <p class="card-text text-muted">@item.Description</p>
                        }
                        <div class="d-flex justify-content-between text-muted small">
                            <span>
                                <i class="align-middle" data-lucide="columns-3" style="width: 14px; height: 14px;"></i>
                                @item.FieldCount @Localizer["fields"]
                            </span>
                            <span>
                                <i class="align-middle" data-lucide="file-text" style="width: 14px; height: 14px;"></i>
                                @item.RecordCount @Localizer["records"]
                            </span>
                        </div>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <small class="text-muted">
                            <label data-utc-time="@item.CreationTime.ToHtmlDateTime()"></label>
                        </small>
                        <div>
                            <a asp-controller="EventRecords" asp-action="Record" asp-route-eventTypeId="@item.Id" class="btn btn-sm btn-success">
                                <i class="align-middle" data-lucide="pen-line" style="width: 14px; height: 14px;"></i> @Localizer["Record"]
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                <i class="align-middle" data-lucide="edit-2" style="width: 14px; height: 14px;"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                                <i class="align-middle" data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
