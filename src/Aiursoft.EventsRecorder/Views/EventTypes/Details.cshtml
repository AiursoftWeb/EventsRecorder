@using Aiursoft.EventsRecorder.Entities
@using Aiursoft.WebTools
@using Newtonsoft.Json
@model Aiursoft.EventsRecorder.Models.EventTypesViewModels.DetailsViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Model.Name</h3>
    </div>
    <div class="col-auto ms-auto text-end mt-n1">
        <a asp-controller="EventRecords" asp-action="Record" asp-route-eventTypeId="@Model.Id" class="btn btn-success">
            <i class="align-middle" data-lucide="pen-line"></i> @Localizer["Record!"]
        </a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">@Localizer["Edit"]</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">@Localizer["Delete"]</a>
        <a asp-action="Index" class="btn btn-light">@Localizer["Back"]</a>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <p class="text-muted">@Model.Description</p>
}

<div class="row">
    <div class="col-md-4 col-xl-3">
        <div class="card mb-3">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Summary"]</h5>
            </div>
            <div class="list-group list-group-flush">
                <div class="list-group-item">
                    <div class="row">
                        <strong class="col-sm-5">@Localizer["Records"]</strong>
                        <div class="col-sm-7">@Model.RecordCount</div>
                    </div>
                </div>
                <div class="list-group-item">
                    <div class="row">
                        <strong class="col-sm-5">@Localizer["Fields"]</strong>
                        <div class="col-sm-7">@Model.Fields.Count</div>
                    </div>
                </div>
                <div class="list-group-item">
                    <div class="row">
                        <strong class="col-sm-5">@Localizer["Created"]</strong>
                        <div class="col-sm-7">
                            <label data-utc-time="@Model.CreationTime.ToHtmlDateTime()"></label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <a asp-controller="EventRecords" asp-action="Index" asp-route-eventTypeId="@Model.Id" class="btn btn-outline-primary w-100 mb-3">
            <i class="align-middle" data-lucide="list"></i> @Localizer["View All Records"]
        </a>
    </div>

    <div class="col-md-8 col-xl-9">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="columns-3"></i> @Localizer["Fields"]</h5>
                <a asp-controller="EventFields" asp-action="Create" asp-route-eventTypeId="@Model.Id" class="btn btn-sm btn-primary">
                    <i class="align-middle" data-lucide="plus" style="width: 14px; height: 14px;"></i> @Localizer["Add Field"]
                </a>
            </div>
            @if (Model.Fields.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                        <tr>
                            <th>@Localizer["Order"]</th>
                            <th>@Localizer["Name"]</th>
                            <th>@Localizer["Type"]</th>
                            <th>@Localizer["Required"]</th>
                            <th class="text-end">@Localizer["Actions"]</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (var field in Model.Fields)
                        {
                            <tr>
                                <td>@field.Order</td>
                                <td>@field.Name</td>
                                <td>
                                    @switch (field.FieldType)
                                    {
                                        case FieldType.String:
                                            <span class="badge bg-info">String</span>
                                            break;
                                        case FieldType.Number:
                                            <span class="badge bg-success">Number</span>
                                            break;
                                        case FieldType.Boolean:
                                            <span class="badge bg-warning">Boolean</span>
                                            break;
                                        case FieldType.Timespan:
                                            <span class="badge bg-secondary">Timespan</span>
                                            break;
                                        case FieldType.File:
                                            <span class="badge bg-primary">File</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (field.IsRequired)
                                    {
                                        <i class="align-middle text-success" data-lucide="check" style="width: 16px; height: 16px;"></i>
                                    }
                                    else
                                    {
                                        <i class="align-middle text-muted" data-lucide="minus" style="width: 16px; height: 16px;"></i>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-controller="EventFields" asp-action="Edit" asp-route-id="@field.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="align-middle" data-lucide="edit-2" style="width: 14px; height: 14px;"></i>
                                    </a>
                                    <form asp-controller="EventFields" asp-action="Delete" asp-route-id="@field.Id" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('@Localizer["Are you sure you want to delete this field?"]')">
                                            <i class="align-middle" data-lucide="trash-2" style="width: 14px; height: 14px;"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body text-center text-muted">
                    <p>@Localizer["No fields defined yet. Add fields to define what data to collect."]</p>
                </div>
            }
        </div>

        @if (Model.Fields.Any(f => f.FieldType == FieldType.Number))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="filter"></i> @Localizer["Filter Trends"]</h5>
                </div>
                <div class="card-body">
                    <form method="get" asp-action="Details" class="row g-3">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="col-md-5">
                            <label class="form-label">@Localizer["Start Date"]</label>
                            <input type="datetime-local" class="form-control" name="start" value="@Model.Start.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">@Localizer["End Date"]</label>
                            <input type="datetime-local" class="form-control" name="end" value="@Model.End.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary w-100">@Localizer["Filter"]</button>
                        </div>
                    </form>
                </div>
            </div>

            @foreach (var series in Model.NumberSeries)
            {
                var canvasId = $"chart_{System.Text.RegularExpressions.Regex.Replace(series.FieldName, "[^a-zA-Z0-9]", "_")}";
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="align-middle me-2" data-lucide="trending-up"></i> @series.FieldName</h5>
                    </div>
                    <div class="card-body">
                        <canvas id="@canvasId" height="300"></canvas>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (Model.Fields.Any(f => f.FieldType == FieldType.Number))
{
    @* ReSharper disable once Razor.SectionNotResolved *@
    @section scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns@3/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var seriesData = @Html.Raw(JsonConvert.SerializeObject(Model.NumberSeries));
                var colors = [
                    'rgb(75, 192, 192)', 'rgb(255, 99, 132)', 'rgb(54, 162, 235)',
                    'rgb(255, 206, 86)', 'rgb(153, 102, 255)', 'rgb(255, 159, 64)',
                    'rgb(46, 204, 113)', 'rgb(231, 76, 60)', 'rgb(52, 152, 219)'
                ];
                
                seriesData.forEach(function (series, idx) {
                    var canvasId = 'chart_' + series.FieldName.replace(/[^a-zA-Z0-9]/g, '_');
                    var canvas = document.getElementById(canvasId);
                    if (!canvas) return;
                    
                    var dataset = {
                        label: series.FieldName,
                        data: series.Points.map(function (p) {
                            return { x: new Date(p.X), y: p.Y };
                        }),
                        borderColor: colors[idx % colors.length],
                        backgroundColor: colors[idx % colors.length] + '33',
                        fill: false,
                        tension: 0.3
                    };

                    new Chart(canvas, {
                        type: 'line',
                        data: { datasets: [dataset] },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                x: {
                                    type: 'time',
                                    time: { tooltipFormat: 'yyyy-MM-dd HH:mm' },
                                    title: { display: true, text: '@Localizer["Time"]' }
                                },
                                y: {
                                    title: { display: true, text: '@Localizer["Value"]' }
                                }
                            },
                            plugins: {
                                legend: { display: true, position: 'top' }
                            }
                        }
                    });
                });
            });
        </script>
    }
}
