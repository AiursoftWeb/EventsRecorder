<div class="text-center mt-5">
    <h1 class="display-4">@Localizer["Events Recorder"]</h1>
    <p class="text-muted mb-4">@Localizer["Define your event types, then record life moments with a single tap."]</p>
    <a asp-controller="EventRecords" asp-action="Record" class="btn btn-success btn-lg px-5 py-3 shadow-sm" style="font-size: 1.5rem;">
        <i class="align-middle me-2" data-lucide="pen-line"></i> @Localizer["Record!"]
    </a>
</div>

<div class="container-fluid p-5">
    <div class="row mb-2 mb-xl-3">
        <div class="col-auto d-none d-sm-block">
            <h3>@Localizer["Quick Links"]</h3>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-12 col-md-6 col-lg-4 mb-3">
            <a asp-controller="EventTypes" asp-action="Index" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="d-inline-block me-3">
                            <div class="stat">
                                <i class="align-middle text-primary" data-lucide="layers"></i>
                            </div>
                        </div>
                        <div>
                            <h5 class="mt-0 mb-1">@Localizer["My Event Types"]</h5>
                            <p class="mb-0 text-muted">@Localizer["Define and manage event types and their fields."]</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4 mb-3">
            <a asp-controller="EventRecords" asp-action="Index" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="d-inline-block me-3">
                            <div class="stat">
                                <i class="align-middle text-success" data-lucide="file-text"></i>
                            </div>
                        </div>
                        <div>
                            <h5 class="mt-0 mb-1">@Localizer["My Records"]</h5>
                            <p class="mb-0 text-muted">@Localizer["View your event recording timeline."]</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4 mb-3">
            <a asp-controller="EventTypes" asp-action="Create" class="text-decoration-none">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="d-inline-block me-3">
                            <div class="stat">
                                <i class="align-middle text-warning" data-lucide="plus-circle"></i>
                            </div>
                        </div>
                        <div>
                            <h5 class="mt-0 mb-1">@Localizer["New Event Type"]</h5>
                            <p class="mb-0 text-muted">@Localizer["Create a new event type to start tracking."]</p>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <div class="row mb-2 mb-xl-3">
        <div class="col-auto d-none d-sm-block">
            <h3>@Localizer["About"]</h3>
        </div>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Why use the Aiursoft Template?"]</h5>
                    <p class="mb-0 text-muted mt-2">@Localizer["A modern, feature-rich, and highly extensible foundation for your next web application."]</p>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="database"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Multiple Database Provider Support"]</h5>
                                    <p>@Localizer["Easily switch between database providers, including SQLite, MySQL, SQL Server, and an in-memory database for testing."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="key-round"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["OpenID Connect Integration"]</h5>
                                    <p>@Localizer["Seamlessly integrate with any OpenID Connect provider, with automatic role synchronization."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="shield-check"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["RBAC Authorization"]</h5>
                                    <p>@Localizer["A built-in Role-Based Access Control (RBAC) system for fine-grained permission management."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="navigation"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Dynamic Navigation Bar"]</h5>
                                    <p>@Localizer["The navigation bar automatically adjusts based on user roles and permissions."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="check-circle-2"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Consistency Validation"]</h5>
                                    <p>@Localizer["Models are validated on both client and server sides based on data annotations."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="languages"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["AI-Powered Translations"]</h5>
                                    <p>@Localizer["Automatic, AI-driven translation into 28 languages."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="book-open-text"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Comprehensive Documentation"]</h5>
                                    <p>@Localizer["Includes extensive documentation and practical examples to get you started quickly."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="user-cog"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Built-in User Management"]</h5>
                                    <p>@Localizer["A complete solution for user authentication and profile management."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="zap"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Automatic Dependency Injection"]</h5>
                                    <p>@Localizer["All dependencies are automatically registered and always available via constructor injection."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="folder-archive"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Integrated File Management"]</h5>
                                    <p>@Localizer["Features a built-in file management system with automatic avatar compression and privacy protection."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="airplay"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Responsive Design"]</h5>
                                    <p>@Localizer["A fully responsive layout that looks great on both desktop and mobile devices."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="moon"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Automatic Dark Mode"]</h5>
                                    <p>@Localizer["Smart dark mode that adapts to the user's system settings."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="ship"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Dockerized for Easy Deployment"]</h5>
                                    <p>@Localizer["Comes with Docker support for simplified and consistent deployments."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="test-tube-2"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Robust Integration Testing"]</h5>
                                    <p>@Localizer["Effortlessly write integration tests using in-memory databases, temporary file systems, built-in mocking, and real-world HTTP request simulation."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="globe"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Automatic Time Zone Handling"]</h5>
                                    <p>@Localizer["Develop exclusively in UTC while the system automatically converts and displays dates in the user's local time zone."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="cpu"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Background Job Processing"]</h5>
                                    <p>@Localizer["\"Fire-and-forget\" support for long-running tasks (like emails or AI), featuring a GUI for queue management, parallel processing, and cancellation."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="calendar-clock"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Scheduled Task Management"]</h5>
                                    <p>@Localizer["Handle recurring jobs like cleanup and synchronization with a comprehensive GUI for monitoring execution history and logs."]</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 d-flex">
                            <div class="d-flex align-items-start py-3">
                                <div class="d-inline-block me-3">
                                    <div class="stat">
                                        <i class="align-middle" data-lucide="settings-2"></i>
                                    </div>
                                </div>
                                <div class="flex-grow-1">
                                    <h5 class="mt-0">@Localizer["Smart Configuration Overrides"]</h5>
                                    <p>@Localizer["Supports both environment variables and database-backed settings, with automatic priority given to environment variables for seamless overrides."]</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
